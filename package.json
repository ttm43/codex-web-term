{
  "name": "codex-web-term",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based multi-session Codex terminal for Windows and macOS.",
  "scripts": {
    "start": "node ./src/server.js",
    "check": "node --check ./src/server.js && node --check ./src/config.js && node --check ./src/sessionManager.js && node --check ./public/app.js && node --check ./scripts/service.mjs && node --check ./scripts/launchd/manage.mjs",
    "pm2:dev": "pm2 startOrReload ecosystem.config.cjs --only codex-web-term-dev --update-env",
    "pm2:prod": "pm2 startOrReload ecosystem.config.cjs --only codex-web-term --update-env",
    "pm2:stop": "pm2 delete codex-web-term codex-web-term-dev",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs codex-web-term --lines 120",
    "service:start": "node ./scripts/service.mjs start --mode prod",
    "service:start:dev": "node ./scripts/service.mjs start --mode dev",
    "service:restart": "node ./scripts/service.mjs restart --mode prod",
    "service:restart:dev": "node ./scripts/service.mjs restart --mode dev",
    "service:stop": "node ./scripts/service.mjs stop",
    "service:status": "node ./scripts/service.mjs status",
    "service:list": "node ./scripts/service.mjs list",
    "service:list:json": "node ./scripts/service.mjs list --json",
    "service:logs": "node ./scripts/service.mjs logs --mode prod",
    "service:logs:dev": "node ./scripts/service.mjs logs --mode dev",
    "service:resurrect": "node ./scripts/service.mjs resurrect --mode prod",
    "launchd:render": "node ./scripts/launchd/manage.mjs render",
    "launchd:install": "node ./scripts/launchd/manage.mjs install",
    "launchd:uninstall": "node ./scripts/launchd/manage.mjs uninstall",
    "launchd:list": "node ./scripts/launchd/manage.mjs list",
    "dev": "npm run service:start:dev",
    "prod": "npm run service:start"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "dotenv": "^17.2.3",
    "node-pty": "^1.0.0",
    "ws": "^8.18.3",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "pm2": "^6.0.8"
  }
}
